import streamlit as st
import yfinance as yf
import numpy as np
import pandas as pd
from scipy.stats import norm
import plotly.graph_objects as go
from datetime import datetime, timedelta
import os

# --- 1. CONFIGURAZIONE PAGINA E CSS ---
st.set_page_config(page_title="OptionStrat Pro - Final Edition", layout="wide")

st.markdown("""
<style>
[data-testid="stMetricValue"] { font-size: 1.25rem !important; }
[data-testid="stMetricLabel"] { font-size: 0.85rem !important; color: #cccccc !important; }
.risk-card {
    background-color: #1e2130;
    padding: 15px;
    border-radius: 10px;
    border-left: 5px solid #00ffcc;
    margin-bottom: 20px;
}
</style>
""", unsafe_allow_html=True)

# --- 2. LOGICA DI SALVATAGGIO PERMANENTE ---
FILE_LOG = "trading_journal_permanente.csv"

def carica_dati_permanenti():
    if os.path.exists(FILE_LOG):
        try:
            df = pd.read_csv(FILE_LOG)
            if not df.empty:
                st.session_state.balance = float(df['Saldo'].iloc[-1])
                st.session_state.trades_history = df.to_dict('records')
                return
        except: pass
    st.session_state.balance = 10000.0
    st.session_state.trades_history = []

def salva_su_file():
    df = pd.DataFrame(st.session_state.trades_history)
    df.to_csv(FILE_LOG, index=False)

if 'inizializzato' not in st.session_state:
    carica_dati_permanenti()
    st.session_state.inizializzato = True

# --- 3. MOTORE BLACK-SCHOLES ---
def bs_engine(S, K, T, r, sigma, option_type="Call"):
    if T <= 0: T = 1e-9 
    d1 = (np.log(S / K) + (r + 0.5 * sigma**2) * T) / (sigma * np.sqrt(T))
    d2 = d1 - sigma * np.sqrt(T)
    if option_type == "Call":
        return S * norm.cdf(d1) - K * np.exp(-r * T) * norm.cdf(d2)
    else:
        return K * np.exp(-r * T) * norm.cdf(-d2) - S * norm.cdf(-d1)

# --- 4. SIDEBAR: ACCOUNT E MODALITÀ ---
st.sidebar.header("💰 Account")
st.session_state.balance = st.sidebar.number_input("Saldo ($)", value=st.session_state.balance, step=100.0)
moltiplicatore = st.sidebar.number_input("Moltiplicatore Azioni", value=100, min_value=1)
comm_per_leg = st.sidebar.number_input("Commissioni/Contratto ($)", value=1.5, step=0.1)

if st.sidebar.button("🗑️ Reset Totale Diario"):
    if os.path.exists(FILE_LOG): os.remove(FILE_LOG)
    st.session_state.clear()
    st.rerun()

st.sidebar.divider()
sorgente_dati = st.sidebar.radio("Sorgente Opzioni:", ["🧮 Matematica", "🌐 Mercato Reale", "📂 CSV Storico"])
ticker = st.sidebar.text_input("Ticker", value="NVDA").upper()
data_ingresso = st.sidebar.date_input("Data Apertura", value=datetime.now() - timedelta(days=30))

# --- 5. RECUPERO DATI SOTTOSTANTE ---
try:
    # 1. Dati intatti per i calcoli logici (ffill previene buchi dati nei weekend)
    df_full = yf.download(ticker, start=data_ingresso, end=datetime.now() + timedelta(days=10), progress=False, auto_adjust=True).ffill()
    prezzo_apertura = float(df_full['Close'].iloc[0].iloc[0] if isinstance(df_full['Close'].iloc[0], pd.Series) else df_full['Close'].iloc[0])
    
    # 2. Dati storici aggiunti (60gg prima) SOLO per il grafico visivo a candele
    df_storico = yf.download(ticker, start=data_ingresso - timedelta(days=60), end=data_ingresso, progress=False, auto_adjust=True).ffill()
    df_chart_complete = pd.concat([df_storico, df_full])
    df_chart_complete = df_chart_complete[~df_chart_complete.index.duplicated(keep='last')]
except Exception as e:
    st.error(f"Errore download dati ticker: {e}")
    st.stop()

# --- 6. GESTIONE SCADENZE ---
durata_originale = 30
strikes_disponibili = []
df_custom = None
chain = None # Inizializziamo chain per sicurezza

if sorgente_dati == "🌐 Mercato Reale":
    tk = yf.Ticker(ticker)
    scadenze = tk.options
    if scadenze:
        etichette = [f"{sc} ({(datetime.strptime(sc, '%Y-%m-%d').date() - data_ingresso).days} gg)" for sc in scadenze]
        scelta = st.sidebar.selectbox("📅 Scadenza Reale", etichette)
        scadenza_scelta = scelta.split(" ")[0]
        durata_originale = max(1, (datetime.strptime(scadenza_scelta, "%Y-%m-%d").date() - data_ingresso).days)
        chain = tk.option_chain(scadenza_scelta)
        strikes_disponibili = sorted(list(set(chain.calls['strike'].tolist() + chain.puts['strike'].tolist())))
    else: 
        sorgente_dati = "🧮 Matematica"
        st.sidebar.warning("Opzioni reali non trovate, passo alla matematica.")

elif sorgente_dati == "📂 CSV Storico":
    file = st.sidebar.file_uploader("Carica CSV", type="csv")
    if file: df_custom = pd.read_csv(file)
    durata_originale = st.sidebar.number_input("Giorni alla scadenza", value=30)
else:
    durata_originale = st.sidebar.number_input("Giorni alla scadenza", value=30)

# --- 7. TIME MACHINE ---
st.sidebar.divider()
max_minuti = int(durata_originale * 24 * 60)
minuti_passati = st.sidebar.slider("Passaggio del tempo", 0, max_minuti, 0, step=30, label_visibility="collapsed")
g, h, m = minuti_passati // 1440, (minuti_passati % 1440) // 60, minuti_passati % 60
st.sidebar.success(f"⏱️ Tempo trascorso: `{g}d - {h}h - {m}m`")

idx_g = min(int(minuti_passati / 1440), len(df_full) - 1)
prezzo_corrente = float(df_full['Close'].iloc[idx_g].iloc[0] if isinstance(df_full['Close'].iloc[idx_g], pd.Series) else df_full['Close'].iloc[idx_g])
data_corrente = df_full.index[idx_g]

# --- 8. SETUP STRATEGIA CON BID/ASK E IV REALE ---
st.subheader(f"Setup Operazione su {ticker} (x{moltiplicatore})")
num_legs = st.number_input("Gambe", 1, 4, 1)
legs = []
cols = st.columns(num_legs)

for i in range(num_legs):
    with cols[i]:
        tipo = st.selectbox(f"Tipo L{i+1}", ["Call", "Put"], key=f"t{i}")
        pos = st.selectbox(f"Posizione", ["Long", "Short"], key=f"p{i}")
        
        premio_ap = 0.0
        vol_real = 0.35 # Valore di default
        
        if sorgente_dati == "🌐 Mercato Reale" and strikes_disponibili and chain is not None:
            idx_c = min(range(len(strikes_disponibili)), key=lambda j: abs(strikes_disponibili[j]-prezzo_apertura))
            strike = st.selectbox(f"Strike L{i+1}", strikes_disponibili, index=idx_c, key=f"kr{i}")
            
            # Peschiamo i dati reali dal mercato
            df_chain = chain.calls if tipo == "Call" else chain.puts
            row = df_chain[df_chain['strike'] == strike]
            
            if not row.empty:
                bid = float(row['bid'].iloc[0])
                ask = float(row['ask'].iloc[0])
                iv = float(row['impliedVolatility'].iloc[0])
                
                # Se l'IV è valida la usiamo, altrimenti fallback al 35%
                vol_real = iv if iv > 0 else 0.35
                
                if pos == "Long":
                    # Chi compra paga l'Ask
                    premio_ap = ask if ask > 0 else bs_engine(prezzo_apertura, strike, durata_originale/365, 0.04, vol_real, tipo)
                    st.caption(f"🛒 Ask (Paghi): ${premio_ap:.2f} | IV: {vol_real*100:.1f}%")
                else:
                    # Chi vende riceve il Bid
                    premio_ap = bid if bid > 0 else bs_engine(prezzo_apertura, strike, durata_originale/365, 0.04, vol_real, tipo)
                    st.caption(f"💰 Bid (Ricevi): ${premio_ap:.2f} | IV: {vol_real*100:.1f}%")
            else:
                premio_ap = bs_engine(prezzo_apertura, strike, durata_originale/365, 0.04, vol_real, tipo)
                st.caption(f"⚠️ Dati non trovati, calcolo BS: ${premio_ap:.2f}")
        else:
            strike = st.number_input(f"Strike L{i+1}", value=float(round(prezzo_apertura, 0)), key=f"km{i}")
            premio_ap = bs_engine(prezzo_apertura, strike, durata_originale/365, 0.04, vol_real, tipo)
            st.caption(f"🧮 Prezzo Teorico: ${premio_ap:.2f}")
            
        qty = st.number_input(f"Contratti", 1, 100, 1, key=f"q{i}")
        legs.append({'tipo': tipo, 'segno': 1 if pos == "Long" else -1, 'strike': strike, 'qty': qty, 'premio_ap': premio_ap, 'vol': vol_real})

# --- 9. CALCOLO CURVE E PARAMETRI ---
s_range = np.linspace(prezzo_apertura * 0.5, prezzo_apertura * 1.5, 1000)
T_rem = max(1e-9, (max_minuti - minuti_passati) / (365 * 24 * 60))

payoff_scad = np.zeros_like(s_range)
valore_ora = np.zeros_like(s_range)
pnl_ora_esatto = 0

for leg in legs:
    if leg['tipo'] == "Call": p_s = np.maximum(s_range - leg['strike'], 0)
    else: p_s = np.maximum(leg['strike'] - s_range, 0)
    payoff_scad += (p_s - leg['premio_ap']) * leg['segno'] * leg['qty'] * moltiplicatore
    
    v_t = np.array([bs_engine(s, leg['strike'], T_rem, 0.04, leg['vol'], leg['tipo']) for s in s_range])
    valore_ora += (v_t - leg['premio_ap']) * leg['segno'] * leg['qty'] * moltiplicatore
    pnl_ora_esatto += (bs_engine(prezzo_corrente, leg['strike'], T_rem, 0.04, leg['vol'], leg['tipo']) - leg['premio_ap']) * leg['segno'] * leg['qty'] * moltiplicatore

tot_comm = num_legs * comm_per_leg * 2
pnl_netto = pnl_ora_esatto - tot_comm

idx_be = np.where(np.diff(np.sign(payoff_scad)))[0]
be_points = s_range[idx_be]

# --- 10. DASHBOARD SUPERIORE ---
st.divider()
m1, m2, m3, m4, m5 = st.columns(5)
m1.metric("P&L Netto", f"${pnl_netto:.2f}", delta=f"{((pnl_netto/st.session_state.balance*100) if st.session_state.balance != 0 else 0):.2f}%")

be_str = ""
for b in be_points:
    be_str += f"${b:.2f} ({((b/prezzo_apertura)-1)*100:+.1f}%) "
m2.metric("Break-even (BE)", be_str if be_str else "Nessuno")

m3.metric("Saldo Globale", f"${st.session_state.balance:.2f}")
m4.metric(f"Prezzo {ticker}", f"${prezzo_corrente:.2f}")
m5.metric("Data Simulata", data_corrente.strftime('%d %b %Y'))

# --- 10.5 GRAFICO CANDELE (Aggiunta Storico) ---
st.subheader("📈 Analisi Dinamica Sottostante")

# Utilizziamo il dataframe combinato per assicurarci di vedere il trend precedente
df_display = df_chart_complete[df_chart_complete.index <= data_corrente].copy()

# Fix multi-index per yfinance
if isinstance(df_display.columns, pd.MultiIndex):
    df_display.columns = df_display.columns.get_level_values(0)

df_display['Dist_Perc'] = ((df_display['Close'] / prezzo_apertura) - 1) * 100

fig_price = go.Figure()
fig_price.add_trace(go.Candlestick(
    x=df_display.index, open=df_display['Open'], high=df_display['High'],
    low=df_display['Low'], close=df_display['Close'], name="Prezzo",
    customdata=df_display['Dist_Perc'],
    hovertemplate="<b>%{x|%d %b}</b><br>O: %{open:.2f}<br>C: %{close:.2f}<br><b>Distanza: %{customdata:+.2f}%</b><extra></extra>"
))
fig_price.add_hline(y=prezzo_apertura, line_dash="dot", line_color="yellow", annotation_text="ENTRY")
fig_price.update_layout(template="plotly_dark", height=400, xaxis_rangeslider_visible=False, margin=dict(l=10,r=10,t=10,b=10))
st.plotly_chart(fig_price, use_container_width=True)

# --- 11. GRAFICO PAYOFF ---
st.subheader("📊 Analisi Payoff & Curve")
distanza_perc = (s_range / prezzo_apertura - 1) * 100

fig = go.Figure()

fig.add_trace(go.Scatter(
    x=s_range, 
    y=valore_ora, 
    name="Valore Ora", 
    line=dict(color='#00ffcc', width=3),
    customdata=distanza_perc,
    hovertemplate="<b>Prezzo:</b> $%{x:.2f}<br><b>Distanza:</b> %{customdata:+.2f}%<br><b>P&L:</b> $%{y:,.2f}<extra></extra>"
))

fig.add_trace(go.Scatter(
    x=s_range, 
    y=payoff_scad, 
    name="A Scadenza", 
    line=dict(color='white', dash='dash'),
    customdata=distanza_perc,
    hovertemplate="<b>Prezzo:</b> $%{x:.2f}<br><b>Distanza:</b> %{customdata:+.2f}%<br><b>P&L Final:</b> $%{y:,.2f}<extra></extra>"
))

for b in be_points:
    fig.add_vline(x=b, line_color="red", line_dash="dot", annotation_text="BE")

fig.add_vline(x=prezzo_apertura, line_color="yellow", annotation_text="ENTRY")
fig.add_vline(x=prezzo_corrente, line_color="orange", annotation_text="LIVE")
fig.add_hline(y=0, line_color="grey")

fig.update_layout(
    template="plotly_dark", 
    height=450, 
    margin=dict(l=10, r=10, t=10, b=10), 
    legend=dict(orientation="h", y=1.1),
    hovermode="x unified"
)
st.plotly_chart(fig, use_container_width=True)

# --- 12. ANALISI RISCHIO ---
st.markdown('<div class="risk-card">', unsafe_allow_html=True)
r1, r2 = st.columns(2)

max_p = np.max(payoff_scad) - tot_comm
max_l = np.min(payoff_scad) - tot_comm

is_inf_p = payoff_scad[-1] > payoff_scad[-2] and payoff_scad[-1] > 10000
is_inf_l = (payoff_scad[0] < payoff_scad[1] and payoff_scad[0] < -10000) or (payoff_scad[-1] < payoff_scad[-2] and payoff_scad[-1] < -10000)

r1.markdown(f"### 📈 Massimo Profitto: <span style='color:#00ff88'>{'∞ Illimitato' if is_inf_p else f'${max_p:,.2f}'}</span>", unsafe_allow_html=True)
r2.markdown(f"### 📉 Massima Perdita: <span style='color:#ff4b4b'>{'∞ Illimitata' if is_inf_l else f'${max_l:,.2f}'}</span>", unsafe_allow_html=True)
st.markdown('</div>', unsafe_allow_html=True)

# --- 13. CHIUSURA E DIARIO ---
if st.button("🔴 CHIUDI POSIZIONE E REGISTRA", use_container_width=True):
    st.session_state.balance += pnl_netto
    st.session_state.trades_history.append({
        'Data': data_corrente.date(), 
        'Ticker': ticker, 
        'P&L': round(pnl_netto, 2), 
        'Saldo': round(st.session_state.balance, 2)
    })
    salva_su_file()
    st.rerun()

if st.session_state.trades_history:
    st.subheader("📝 Trading Journal")
    st.dataframe(pd.DataFrame(st.session_state.trades_history), use_container_width=True)
